{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "completedSessions": { "type": "integer" },
        "totalMinutes": { "type": "integer" }
      },
      "required": ["id", "email"]
    },
    "Pose": {
      "title": "Pose",
      "description": "Yoga pose details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sanskrit": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string" },
        "benefits": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "User class reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "classId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["confirmed", "cancelled"] }
      },
      "required": ["id", "userId", "classId", "timestamp", "status"]
    },
    "ClassStats": {
      "title": "ClassStats",
      "description": "Real-time statistics for a class",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "capacity": { "type": "integer" },
        "bookedCount": { "type": "integer" }
      },
      "required": ["classId", "capacity", "bookedCount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/poses/{poseId}": {
      "schema": "Pose",
      "description": "Yoga poses collection"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Class bookings"
    },
    "/class_stats/{classId}": {
      "schema": "ClassStats",
      "description": "Class capacity and booking counts"
    }
  }
}
