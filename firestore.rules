rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - id: string (required)
    //   - name: string
    //   - email: string (required)
    //   - photoURL: string
    //   - favorites: list (strings)
    //   - completedSessions: number
    //   - totalMinutes: number
    //   - bio: string
    //   - gender: string
    //   - hobby: string
    //
    // Collection: poses
    // Document ID: {poseId}
    // Fields:
    //   - id: string
    //   - name: string
    //   - sanskrit: string
    //   - category: string
    //   - difficulty: string
    //   - benefits: list (strings)
    //   - image: string
    //
    // ===============================================================

    // Collection: class_stats
    // Document ID: {classId}
    // Fields:
    //   - classId: string
    //   - capacity: number
    //   - bookedCount: number
    //
    // Collection: bookings
    // Document ID: {bookingId}
    // Fields:
    //   - id: string
    //   - userId: string
    //   - classId: string
    //   - timestamp: string
    //   - status: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email']) &&
             data.id is string &&
             data.email is string &&
             data.email.size() < 255 &&
             (!('name' in data) || (data.name is string && data.name.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000)) &&
             (!('favorites' in data) || (data.favorites is list && data.favorites.size() < 100)) &&
             (!('completedSessions' in data) || (data.completedSessions is number)) &&
             (!('totalMinutes' in data) || (data.totalMinutes is number)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 500)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() < 50)) &&
             (!('hobby' in data) || (data.hobby is string && data.hobby.size() < 100));
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['id', 'userId', 'classId', 'timestamp', 'status']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.classId is string &&
             data.timestamp is string &&
             data.status in ['confirmed', 'cancelled'] &&
             data.id.size() < 100 &&
             data.classId.size() < 100;
    }

    function isValidClassStats(data) {
      return data.keys().hasAll(['classId', 'capacity', 'bookedCount']) &&
             data.classId is string &&
             data.capacity is number &&
             data.capacity > 0 &&
             data.capacity <= 100 &&
             data.bookedCount is number &&
             data.bookedCount >= 0 &&
             data.bookedCount <= data.capacity;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "rzmaan1209@gmail.com" || 
         request.auth.token.email == "shibu082001@gmail.com") && 
        request.auth.token.email_verified == true;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /poses/{poseId} {
      allow read: if true; // Poses are public
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBooking(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidBooking(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /class_stats/{classId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidClassStats(request.resource.data);
      allow update: if isAuthenticated() && isValidClassStats(request.resource.data);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
